{
  "name": "@adminforth/json-editor",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "homepage": "https://adminforth.dev/docs/tutorial/Plugins/json-editor/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rsync -av --exclude 'node_modules' custom dist/"
  },
  "keywords": [
    "adminforth",
    "json",
    "json-editor",
    "monaco",
    "editor"
  ],
  "author": "DevForth (https://devforth.io)",
  "license": "MIT",
  "description": "JSON editor plugin for AdminForth with Monaco Editor support",
  "repository": {
    "type": "git",
    "url": "https://github.com/devforth/adminforth-json-editor.git"
  },
  "devDependencies": {
    "@types/node": "latest",
    "adminforth": "^3.2.9",
    "semantic-release": "^24.2.1",
    "semantic-release-slack-bot": "^4.0.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "adminforth": "^3.2.9"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "semantic-release-slack-bot",
        {
          "packageName": "@adminforth/json-editor",
          "notifyOnSuccess": true,
          "notifyOnFail": true,
          "slackIcon": ":package:",
          "markdownReleaseNotes": true
        }
      ]
    ],
    "branches": [
      "main",
      {
        "name": "next",
        "prerelease": true
      }
    ]
  }
}
